# AI Evaluation SDK - Test Environment Variables
# Copy this to .env and fill in your values

# Required: API Keys (get from platform or database)
FI_API_KEY=your_api_key_here
FI_SECRET_KEY=your_secret_key_here

# Optional: Custom endpoint (defaults to https://api.futureagi.com)
FI_BASE_URL=http://localhost:8000

# Optional: For local LLM testing
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-api03-...
