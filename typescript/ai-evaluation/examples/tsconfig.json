{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "../dist/examples",
    "rootDir": ".",
    "baseUrl": ".."
  },
  "include": ["./*.ts"],
  "exclude": ["node_modules"]
}
